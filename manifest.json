{
  "manifest_version": 3,
  "name": "Tab History Back",
  "description": "Move back through recently active Chrome tabs with one shortcut.",
  "version": "0.1.1",
  "permissions": ["tabs", "storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Tab Back",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-previous-tab": {
      "suggested_key": {
        "default": "Ctrl+Q"
      },
      "description": "Toggle between the current tab and the previous tab"
    },
    "go-back-tab-history": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q"
      },
      "description": "Go back one step in tab activation history"
    }
  }
}
